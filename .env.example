# ============================================
#  Environment Variables for Pterodactyl Panel
# ============================================
# Copy this and fill in your values
# Set these in Railway → Panel Service → Variables
# ============================================

# App
APP_URL=http://localhost
APP_KEY=
APP_TIMEZONE=UTC
APP_LOCALE=en

# App Service (change to your Railway domain)
APP_SERVICE_AUTHOR="Pterodactyl"
APP_SERVICE_NAME="Pterodactyl Panel"

# Database (auto-filled by Railway service reference)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pterodactyl
DB_USERNAME=pterodactyl
DB_PASSWORD=

# Redis (auto-filled by Railway service reference)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Cache & Session (use redis)
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Mail (optional, for password reset)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="Pterodactyl"

# Trust proxies (important for Railway)
TRUSTED_PROXIES=*
